---
import PageLayout from '../../layouts/PageLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { languages, loadTranslations } from '../../i18n/index';
import type { Language } from '../../i18n/index';
import { changelog } from '../../data/changelog';

export function getStaticPaths() {
  const languagePaths = Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));

  return [
    ...languagePaths,
    { params: { lang: undefined } }
  ];
}

const lang = (Astro.params.lang || 'en') as Language;

if (!(lang in languages)) {
  return Astro.redirect('/');
}

const translationData = await loadTranslations(lang);
const t = useTranslations(translationData);
---

<PageLayout
  title={t('seo.home.title')}
  description={t('seo.home.description')}
>
  <main>
    <div class="container">
      <div class="hero">
        <h1>
          <span class="brand-name">{t('seo.home.h1.brand')}</span>
          <span class="subtitle-text">{t('seo.home.h1.subtitle')}</span>
        </h1>
        <p class="subtitle">{t('hero.subtitle')}</p>
      </div>

      <div class="card administrator-corner">
        <h2>{t('administrator.title')}</h2>
        <p>{t('administrator.description')}</p>
      </div>

      <section class="info">
        <div class="card welcome-card">
          <h2>{t('welcome.title')}</h2>
          <p>{t('welcome.description')}</p>
        </div>

        <div class="card changelog-card">
          <h2>{t('changelog.title')}</h2>
          <p class="changelog-subtitle">{t('changelog.subtitle')}</p>
          <ul class="changelog-list">
            {changelog.slice(0, 10).map(entry => (
              <li class="changelog-entry">
                <time class="changelog-date" datetime={entry.date}>
                  {entry.date} — {entry.time}
                </time>
                <span class="changelog-text">{entry.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card support-card">
          <h2>{t('support.title')}</h2>
          <p>{t('support.text')}</p>
          <!-- BUY_ME_A_COFFEE_LINK_PLACEHOLDER -->
          <p class="support-coming-soon">{t('support.comingSoon')}</p>
        </div>
      </section>
    </div>
  </main>
</PageLayout>

<style>
  main {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .container {
    width: 100%;
    position: relative;
  }

  .administrator-corner {
    position: absolute;
    top: 0;
    right: 0;
    max-width: 280px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 165, 0, 0.15);
    border-radius: 8px;
    padding: 1rem;
    backdrop-filter: blur(10px);
    font-size: 0.85rem;
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .administrator-corner:hover {
    opacity: 1;
    border-color: rgba(255, 165, 0, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .administrator-corner h2 {
    color: rgba(255, 165, 0, 0.8);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .administrator-corner p {
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    margin: 0;
  }

  .hero {
    text-align: center;
    margin-bottom: 4rem;
    padding-right: 300px;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #ff6b35 0%, #ffa500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hero h1 .brand-name {
    font-size: 4rem;
    font-weight: 700;
  }

  .hero h1 .subtitle-text {
    font-size: 2rem;
    font-weight: 400;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #ffa500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 12px;
    padding: 2rem;
    backdrop-filter: blur(10px);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(255, 165, 0, 0.2);
  }

  .card h2 {
    color: #ffa500;
    margin-bottom: 1rem;
    font-size: 1.8rem;
  }

  .card h3 {
    color: #ffa500;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .card p {
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  .card ul {
    list-style: none;
  }

  .card li {
    padding: 0.5rem 0;
    color: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid rgba(255, 165, 0, 0.1);
  }

  .card li:last-child {
    border-bottom: none;
  }

  .card strong {
    color: #ffa500;
  }

  .welcome-card {
    grid-column: 1 / -1;
  }

  /* Changelog */
  .changelog-card {
    grid-column: 1 / -1;
  }

  .changelog-subtitle {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.85rem;
    margin: -0.5rem 0 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .changelog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .changelog-entry {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(255, 165, 0, 0.08);
    align-items: baseline;
  }

  .changelog-entry:last-child {
    border-bottom: none;
  }

  .changelog-date {
    color: rgba(255, 165, 0, 0.6);
    font-size: 0.78rem;
    font-family: monospace;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .changelog-text {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Support / Buy me a coffee */
  .support-card {
    grid-column: 1 / -1;
    background: rgba(255, 165, 0, 0.04);
    border-color: rgba(255, 165, 0, 0.2);
    text-align: center;
  }

  .support-card h2 {
    font-size: 1.4rem;
  }

  .support-card p {
    max-width: 560px;
    margin: 0 auto;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .support-coming-soon {
    margin-top: 1rem !important;
    font-size: 0.8rem !important;
    color: rgba(255, 165, 0, 0.5) !important;
    font-style: italic;
  }

  @media (max-width: 1024px) {
    .hero {
      padding-right: 0;
    }

    .administrator-corner {
      position: static;
      max-width: 100%;
      margin-bottom: 2rem;
    }
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.2rem;
    }

    .info {
      grid-template-columns: 1fr;
    }

    .changelog-entry {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
