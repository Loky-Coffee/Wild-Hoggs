---
import PageLayout from '../../layouts/PageLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { languages, loadTranslations } from '../../i18n/index';
import type { Language } from '../../i18n/index';
import { changelog } from '../../data/changelog';

export function getStaticPaths() {
  const languagePaths = Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));

  return [
    ...languagePaths,
    { params: { lang: undefined } }
  ];
}

const lang = (Astro.params.lang || 'en') as Language;

if (!(lang in languages)) {
  return Astro.redirect('/');
}

const translationData = await loadTranslations(lang);
const t = useTranslations(translationData);
---

<PageLayout
  title={t('seo.home.title')}
  description={t('seo.home.description')}
>
  <main class="home-page">
    <div class="container">
      <div class="hero">
        <h1>
          <span class="brand-name">{t('seo.home.h1.brand')}</span>
          <span class="subtitle-text">{t('seo.home.h1.subtitle')}</span>
        </h1>
        <p class="subtitle">{t('hero.subtitle')}</p>
      </div>

      <div class="card administrator-corner">
        <h2>{t('administrator.title')}</h2>
        <p>{t('administrator.description')}</p>
      </div>

      <section class="info">
        <div class="card welcome-card">
          <h2>{t('welcome.title')}</h2>
          <p>{t('welcome.description')}</p>
        </div>

        <div class="card changelog-card">
          <h2>{t('changelog.title')}</h2>
          <p class="changelog-subtitle">{t('changelog.subtitle')}</p>
          <ul class="changelog-list" id="changelog-list">
            {changelog.map((entry, i) => (
              <li class="changelog-entry" data-index={i}>
                <time class="changelog-date" datetime={entry.date}>
                  {entry.date} — {entry.time}
                </time>
                <span class="changelog-text">{entry.text}</span>
              </li>
            ))}
          </ul>
          <button
            class="changelog-show-btn"
            id="changelog-toggle"
            aria-expanded="false"
            data-label-show={t('changelog.showAll')}
            data-label-hide={t('changelog.showLess')}
          >
            {t('changelog.showAll')}
          </button>
        </div>

        <div class="card support-card">
          <div class="support-card-text">
            <h2>{t('support.title')}</h2>
            <p>{t('support.text')}</p>
          </div>
          <div class="bmc-row">
            <a
              href="https://www.buymeacoffee.com/ediva"
              target="_blank"
              rel="noopener noreferrer"
              class="bmc-button"
            >
              ☕ Buy me a coffee
            </a>
            <a href="https://www.buymeacoffee.com/ediva" target="_blank" rel="noopener noreferrer" class="bmc-qr-wrap">
              <img src="/bmc_qr.webp" alt="Buy me a coffee QR code" width="80" height="80" class="bmc-qr" />
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</PageLayout>

<script is:inline>
(function () {
  var SHOW_COUNT = 5;

  function init() {
    var isMobile = window.innerWidth <= 768;
    var btn = document.getElementById('changelog-toggle');
    var entries = document.querySelectorAll('.changelog-entry');

    if (!btn || !entries.length) return;

    if (isMobile) {
      // Show button, apply initial hidden state
      btn.style.display = '';
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      entries.forEach(function (el) {
        var idx = parseInt(el.getAttribute('data-index') || '0', 10);
        if (idx >= SHOW_COUNT) {
          el.classList.toggle('cl-hidden', !expanded);
        } else {
          el.classList.remove('cl-hidden');
        }
      });
    } else {
      // Desktop: show all, hide button
      btn.style.display = 'none';
      entries.forEach(function (el) { el.classList.remove('cl-hidden'); });
    }
  }

  function setupToggle() {
    var btn = document.getElementById('changelog-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      var next = !expanded;
      btn.setAttribute('aria-expanded', String(next));
      btn.textContent = next
        ? (btn.getAttribute('data-label-hide') || btn.textContent)
        : (btn.getAttribute('data-label-show') || btn.textContent);
      var entries = document.querySelectorAll('.changelog-entry');
      entries.forEach(function (el) {
        var idx = parseInt(el.getAttribute('data-index') || '0', 10);
        if (idx >= SHOW_COUNT) {
          el.classList.toggle('cl-hidden', !next);
        }
      });
    });
  }

  function setup() {
    init();
    setupToggle();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
  document.addEventListener('astro:after-swap', setup);
})();
</script>

<style>
  /* ── Base (all screen sizes) ── */
  main {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem 1rem;
  }

  .container {
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .administrator-corner {
    position: absolute;
    top: 0;
    right: 0;
    max-width: 280px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 165, 0, 0.15);
    border-radius: 8px;
    padding: 1rem;
    backdrop-filter: blur(10px);
    font-size: 0.85rem;
    opacity: 0.7;
    transition: opacity 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    z-index: 1;
  }

  .administrator-corner:hover {
    opacity: 1;
    border-color: rgba(255, 165, 0, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .administrator-corner h2 {
    color: rgba(255, 165, 0, 0.8);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .administrator-corner p {
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    margin: 0;
  }

  .hero {
    text-align: center;
    padding-right: 300px;
    flex-shrink: 0;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #ff6b35 0%, #ffa500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hero h1 .brand-name {
    font-size: 4rem;
    font-weight: 700;
  }

  .hero h1 .subtitle-text {
    font-size: 2rem;
    font-weight: 400;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #ffa500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    backdrop-filter: blur(10px);
  }

  .card h2 {
    color: #ffa500;
    margin-bottom: 0.6rem;
    font-size: 1.4rem;
  }

  .card p {
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Welcome card — compact, no grow */
  .welcome-card {
    flex-shrink: 0;
  }

  .welcome-card p {
    font-size: 0.95rem;
    margin: 0;
  }

  /* Changelog card — fills remaining space */
  .changelog-card {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .changelog-subtitle {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.78rem;
    margin: -0.25rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .changelog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    /* custom scrollbar */
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 165, 0, 0.3) transparent;
  }

  .changelog-list::-webkit-scrollbar {
    width: 5px;
  }

  .changelog-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .changelog-list::-webkit-scrollbar-thumb {
    background: rgba(255, 165, 0, 0.3);
    border-radius: 3px;
  }

  .changelog-entry {
    display: grid;
    grid-template-columns: 155px 1fr;
    gap: 1rem;
    padding: 0.5rem 0.25rem;
    border-bottom: 1px solid rgba(255, 165, 0, 0.07);
    align-items: baseline;
  }

  .changelog-entry:last-child {
    border-bottom: none;
  }

  .changelog-date {
    color: rgba(255, 165, 0, 0.55);
    font-size: 0.75rem;
    font-family: monospace;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .changelog-text {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  /* Support / Buy me a coffee — compact, no grow */
  .support-card {
    flex-shrink: 0;
    background: rgba(255, 165, 0, 0.04);
    border-color: rgba(255, 165, 0, 0.2);
    text-align: center;
  }

  .support-card p {
    max-width: 560px;
    margin: 0 auto;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .bmc-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .bmc-button {
    display: inline-block;
    padding: 0.55rem 1.4rem;
    background: #ffa500;
    color: #1a1a1a;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .bmc-button:hover {
    background: #ff8c00;
    transform: translateY(-2px);
  }

  .bmc-qr-wrap {
    display: inline-flex;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    padding: 4px;
    line-height: 0;
    transition: transform 0.2s ease;
  }

  .bmc-qr-wrap:hover {
    transform: translateY(-2px);
  }

  .bmc-qr {
    display: block;
    border-radius: 4px;
  }

  /* Desktop: text left, bmc-row right */
  @media (min-width: 769px) {
    .support-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      text-align: left;
    }

    .support-card-text {
      flex: 1;
      min-width: 0;
    }

    .support-card p {
      margin: 0;
      max-width: none;
    }

    .bmc-row {
      margin-top: 0;
      flex-wrap: nowrap;
      flex-shrink: 0;
    }

    .bmc-button {
      padding: 0.7rem 1.8rem;
      font-size: 1.05rem;
    }

    .bmc-qr {
      width: 60px;
      height: 60px;
    }
  }

  /* ── Desktop: fixed viewport height, no page scroll ── */
  @media (min-width: 769px) {
    main {
      flex: 1;        /* grow inside .page-content flex column */
      min-height: 0;  /* allow shrinking below content size */
      overflow: hidden;
    }

    .container {
      flex: 1;
      min-height: 0;
      overflow: hidden;
    }

    .info {
      flex: 1;
      min-height: 0;
      overflow: hidden;
    }
  }

  /* ── Tablet: administrator-corner goes static ── */
  @media (max-width: 1024px) {
    .hero {
      padding-right: 0;
      margin-bottom: 0;
    }

    .administrator-corner {
      position: static;
      max-width: 100%;
      margin-bottom: 0.75rem;
    }
  }

  /* ── Mobile: normal page scroll, date stacks above text ── */
  @media (max-width: 768px) {
    main {
      padding: 1rem 1rem 2rem;
    }

    .hero h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.2rem;
    }

    .changelog-card {
      flex: none;
    }

    .changelog-list {
      overflow-y: visible;
    }

    .changelog-entry {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }

    .changelog-entry.cl-hidden {
      display: none;
    }

    .changelog-show-btn {
      display: block;
      width: 100%;
      margin-top: 0.75rem;
      padding: 0.5rem;
      background: none;
      border: 1px solid rgba(255, 165, 0, 0.3);
      border-radius: 6px;
      color: rgba(255, 165, 0, 0.8);
      font-size: 0.85rem;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    .changelog-show-btn:hover {
      background: rgba(255, 165, 0, 0.08);
      border-color: rgba(255, 165, 0, 0.55);
    }
  }
</style>

<style is:global>
  /* Homepage only: lock body to viewport height on desktop */
  @media (min-width: 769px) {
    body:has(.home-page) {
      height: 100dvh;
      overflow: hidden;
    }

    body:has(.home-page) .page-content {
      height: calc(100dvh - var(--nav-height));
      overflow: hidden;
      display: flex;
      flex-direction: column;
      padding-bottom: 0;
    }
  }
</style>
