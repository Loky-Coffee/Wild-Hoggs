---
import PageLayout from '../../layouts/PageLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { languages, loadTranslations } from '../../i18n/index';
import type { Language } from '../../i18n/index';
import { changelog } from '../../data/changelog';

export function getStaticPaths() {
  const languagePaths = Object.keys(languages)
    .filter(lang => lang !== 'en')
    .map(lang => ({ params: { lang } }));

  return [
    ...languagePaths,
    { params: { lang: undefined } }
  ];
}

const lang = (Astro.params.lang || 'en') as Language;

if (!(lang in languages)) {
  return Astro.redirect('/');
}

const translationData = await loadTranslations(lang);
const t = useTranslations(translationData);
---

<PageLayout
  title={t('seo.home.title')}
  description={t('seo.home.description')}
>
  <main class="home-page">
    <div class="container">
      <div class="hero">
        <h1>
          <span class="brand-name">{t('seo.home.h1.brand')}</span>
          <span class="subtitle-text">{t('seo.home.h1.subtitle')}</span>
        </h1>
        <p class="subtitle">{t('hero.subtitle')}</p>
      </div>

      <div class="card administrator-corner">
        <h2>{t('administrator.title')}</h2>
        <p>{t('administrator.description')}</p>
      </div>

      <section class="info">
        <div class="card welcome-card">
          <h2>{t('welcome.title')}</h2>
          <p>{t('welcome.description')}</p>
        </div>

        <div class="card changelog-card">
          <h2>{t('changelog.title')}</h2>
          <p class="changelog-subtitle">{t('changelog.subtitle')}</p>
          <ul class="changelog-list">
            {changelog.map(entry => (
              <li class="changelog-entry">
                <time class="changelog-date" datetime={entry.date}>
                  {entry.date} — {entry.time}
                </time>
                <span class="changelog-text">{entry.text}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card support-card">
          <h2>{t('support.title')}</h2>
          <p>{t('support.text')}</p>
          <!-- BUY_ME_A_COFFEE_LINK_PLACEHOLDER -->
          <p class="support-coming-soon">{t('support.comingSoon')}</p>
        </div>
      </section>
    </div>
  </main>
</PageLayout>

<style>
  /* ── Base (all screen sizes) ── */
  main {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem 1rem;
  }

  .container {
    width: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .administrator-corner {
    position: absolute;
    top: 0;
    right: 0;
    max-width: 280px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 165, 0, 0.15);
    border-radius: 8px;
    padding: 1rem;
    backdrop-filter: blur(10px);
    font-size: 0.85rem;
    opacity: 0.7;
    transition: opacity 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    z-index: 1;
  }

  .administrator-corner:hover {
    opacity: 1;
    border-color: rgba(255, 165, 0, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .administrator-corner h2 {
    color: rgba(255, 165, 0, 0.8);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .administrator-corner p {
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    margin: 0;
  }

  .hero {
    text-align: center;
    padding-right: 300px;
    flex-shrink: 0;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #ff6b35 0%, #ffa500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hero h1 .brand-name {
    font-size: 4rem;
    font-weight: 700;
  }

  .hero h1 .subtitle-text {
    font-size: 2rem;
    font-weight: 400;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #ffa500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    backdrop-filter: blur(10px);
  }

  .card h2 {
    color: #ffa500;
    margin-bottom: 0.6rem;
    font-size: 1.4rem;
  }

  .card p {
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Welcome card — compact, no grow */
  .welcome-card {
    flex-shrink: 0;
  }

  .welcome-card p {
    font-size: 0.95rem;
    margin: 0;
  }

  /* Changelog card — fills remaining space */
  .changelog-card {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .changelog-subtitle {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.78rem;
    margin: -0.25rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .changelog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    /* custom scrollbar */
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 165, 0, 0.3) transparent;
  }

  .changelog-list::-webkit-scrollbar {
    width: 5px;
  }

  .changelog-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .changelog-list::-webkit-scrollbar-thumb {
    background: rgba(255, 165, 0, 0.3);
    border-radius: 3px;
  }

  .changelog-entry {
    display: grid;
    grid-template-columns: 155px 1fr;
    gap: 1rem;
    padding: 0.5rem 0.25rem;
    border-bottom: 1px solid rgba(255, 165, 0, 0.07);
    align-items: baseline;
  }

  .changelog-entry:last-child {
    border-bottom: none;
  }

  .changelog-date {
    color: rgba(255, 165, 0, 0.55);
    font-size: 0.75rem;
    font-family: monospace;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .changelog-text {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  /* Support / Buy me a coffee — compact, no grow */
  .support-card {
    flex-shrink: 0;
    background: rgba(255, 165, 0, 0.04);
    border-color: rgba(255, 165, 0, 0.2);
    text-align: center;
  }

  .support-card p {
    max-width: 560px;
    margin: 0 auto;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .support-coming-soon {
    margin-top: 0.5rem !important;
    font-size: 0.78rem !important;
    color: rgba(255, 165, 0, 0.45) !important;
    font-style: italic;
  }

  /* ── Desktop: fixed viewport height, no page scroll ── */
  @media (min-width: 769px) {
    main {
      height: 100%;
      overflow: hidden;
    }

    .container {
      height: 100%;
      overflow: hidden;
    }
  }

  /* ── Tablet: administrator-corner goes static ── */
  @media (max-width: 1024px) {
    .hero {
      padding-right: 0;
      margin-bottom: 0;
    }

    .administrator-corner {
      position: static;
      max-width: 100%;
      margin-bottom: 0.75rem;
    }
  }

  /* ── Mobile: normal page scroll, date stacks above text ── */
  @media (max-width: 768px) {
    main {
      padding: 1rem 1rem 2rem;
    }

    .hero h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.2rem;
    }

    .changelog-card {
      flex: none;
    }

    .changelog-list {
      overflow-y: visible;
    }

    .changelog-entry {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>

<style is:global>
  /* Homepage only: lock body to viewport height on desktop */
  @media (min-width: 769px) {
    body:has(.home-page) {
      height: 100dvh;
      overflow: hidden;
    }

    body:has(.home-page) .page-content {
      height: calc(100dvh - var(--nav-height));
      overflow: hidden;
      display: flex;
      flex-direction: column;
      padding-bottom: 0;
    }
  }
</style>
