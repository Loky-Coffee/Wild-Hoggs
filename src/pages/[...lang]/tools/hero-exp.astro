---
// Alte Tool-URL — jetzt Teil des Helden-Hubs (/heroes, Tab „EXP"). Weiterleitung dorthin.
import { getLangFromUrl, getLocalizedPath } from '../../../i18n/utils';
import { getLanguagePaths } from '../../../i18n/static-paths';

export function getStaticPaths() {
  return getLanguagePaths();
}

const lang = getLangFromUrl(Astro.url);
const heroesPath = getLocalizedPath('heroes', lang);
const target = `${heroesPath}#exp`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={heroesPath} />
    <meta name="robots" content="noindex, follow" />
    <title>Redirecting…</title>
    <script is:inline set:html={`location.replace(${JSON.stringify(target)});`} />
  </head>
  <body>
    <p>→ <a href={target}>Hero EXP</a></p>
  </body>
</html>
