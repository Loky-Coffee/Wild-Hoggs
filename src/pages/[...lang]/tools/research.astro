---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getCurrentYear } from '../../../i18n/utils';
import { getLanguagePaths } from '../../../i18n/static-paths';
import { loadTranslations } from '../../../i18n/index';
import { Image } from 'astro:assets';

// Import all research category data
import allianceRecognition from '../../../data/research/alliance-recognition.json';
import unitSpecialTraining from '../../../data/research/unit-special-training.json';
import fullyArmedAlliance from '../../../data/research/fully-armed-alliance.json';
import field from '../../../data/research/field.json';
import heroTraining from '../../../data/research/hero-training.json';
import militaryStrategies from '../../../data/research/military-strategies.json';
import peaceShield from '../../../data/research/peace-shield.json';
import siegeToSeize from '../../../data/research/siege-to-seize.json';
import armyBuilding from '../../../data/research/army-building.json';
import '../../../styles/shared-layouts.css';

// Import optimized images
import type { ImageMetadata } from 'astro';
import allianceRecognitionImg from '../../../assets/images/research/alliance-recognition.webp';
import unitSpecialTrainingImg from '../../../assets/images/research/unit-special-training.webp';
import fullyArmedAllianceImg from '../../../assets/images/research/fully-armed-alliance.webp';
import fieldImg from '../../../assets/images/research/field.webp';
import heroTrainingImg from '../../../assets/images/research/hero-training.webp';
import militaryStrategiesImg from '../../../assets/images/research/military-strategies.webp';
import peaceShieldImg from '../../../assets/images/research/peace-shield.webp';
import siegeToSeizeImg from '../../../assets/images/research/siege-to-seize.webp';
import armyBuildingImg from '../../../assets/images/research/army-building.webp';

export function getStaticPaths() {
  return getLanguagePaths();
}

const lang = getLangFromUrl(Astro.url);
const translationData = await loadTranslations(lang);
const t = useTranslations(translationData);
const currentYear = getCurrentYear();

// Map category data by ID
const researchDataMap: Record<string, any> = {
  alliance_recognition: allianceRecognition,
  unit_special_training: unitSpecialTraining,
  fully_armed_alliance: fullyArmedAlliance,
  field: field,
  hero_training: heroTraining,
  military_strategies: militaryStrategies,
  peace_shield: peaceShield,
  siege_to_seize: siegeToSeize,
  army_building: armyBuilding,
};

// Map optimized images by ID
const imageMap: Record<string, ImageMetadata> = {
  alliance_recognition: allianceRecognitionImg,
  unit_special_training: unitSpecialTrainingImg,
  fully_armed_alliance: fullyArmedAllianceImg,
  field: fieldImg,
  hero_training: heroTrainingImg,
  military_strategies: militaryStrategiesImg,
  peace_shield: peaceShieldImg,
  siege_to_seize: siegeToSeizeImg,
  army_building: armyBuildingImg,
};

const categories = [
  { id: 'unit_special_training', icon: '🎖️' },
  { id: 'fully_armed_alliance', icon: '⚔️' },
  { id: 'field', icon: '🏕️' },
  { id: 'alliance_recognition', icon: '🏆' },
  { id: 'military_strategies', icon: '📋' },
  { id: 'peace_shield', icon: '🛡️' },
  { id: 'siege_to_seize', icon: '🏰' },
  { id: 'hero_training', icon: '💪' },
  { id: 'army_building', icon: '🪖' },
];

const breadcrumbItems = [
  { label: t('nav.home'), href: getLocalizedPath('', lang) },
  { label: t('nav.tools'), href: getLocalizedPath('tools', lang) },
  { label: t('tools.research.title') }
];
---

<PageLayout
  title={t('seo.research.title', { year: currentYear })}
  description={t('seo.research.description')}
  breadcrumbs={breadcrumbItems}
  image="/og-lab.webp"
  imageAlt={t('seo.research.title', { year: currentYear })}
>
  <div class="page-header">
    <h1>{t('seo.research.h1', { year: currentYear })}</h1>
    <p class="subtitle">{t('research.subtitle')}</p>
  </div>

  <div class="categories-grid">
    {categories.map(({ id, icon }) => {
      const category = researchDataMap[id];
      if (!category) return null;

      const isEnabled = ['alliance_recognition', 'hero_training', 'military_strategies', 'unit_special_training', 'field', 'fully_armed_alliance', 'peace_shield', 'siege_to_seize', 'army_building'].includes(id);
      const CardTag = isEnabled ? 'a' : 'div';

      return (
        <CardTag
          href={isEnabled ? getLocalizedPath(`tools/research/${id}`, lang) : undefined}
          class={`category-card ${!isEnabled ? 'disabled' : ''}`}
          data-category-id={id}
          data-total-badges={String(category.totalBadges)}
          data-total-levels={String(category.totalLevels)}
          data-badge-map={JSON.stringify(Object.fromEntries((category.technologies as {id:string;badgeCosts:number[]}[]).map(t => [t.id, t.badgeCosts])))}>

          <span class="max-badge" data-max-badge>0%</span>
          <div class="category-icon-wrapper">
            {imageMap[id] ? (
              <Image
                src={imageMap[id]}
                alt={t(category.nameKey)}
                class="category-image"
                width={80}
                height={80}
                loading="lazy"
              />
            ) : (
              <div class="category-icon">{icon}</div>
            )}
          </div>
          <h2>{t(category.nameKey)}</h2>
          <div class="category-stats">
            <div class="stat">
              <span class="stat-value"><span data-used>0</span> / {category.totalBadges.toLocaleString(lang === 'de' ? 'de-DE' : 'en-US')}</span>
              <span class="stat-label">🎖️ Badges · <span data-pct>0%</span></span>
            </div>
          </div>
          {isEnabled ? (
            <span class="available">{t('research.available')}</span>
          ) : (
            <span class="coming-soon">{t('research.comingSoon')}</span>
          )}
        </CardTag>
      );
    })}
  </div>
</PageLayout>

<style>
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
      gap: 1.25rem;
    }

    .category-card {
      padding: 1.75rem;
    }

    .category-image {
      width: 80px;
      height: 80px;
    }

    .category-icon {
      font-size: 3rem;
    }

    .category-card h2 {
      font-size: 1.2rem;
      margin-bottom: 1.25rem;
    }

    .stat-value {
      font-size: 1.1rem;
    }
  }

  .category-card {
    position: relative;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .category-card:hover {
    border-color: rgba(255, 165, 0, 0.5);
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(255, 165, 0, 0.2);
  }

  .category-card.disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .category-card.disabled:hover {
    border-color: rgba(255, 165, 0, 0.2);
    transform: none;
    box-shadow: none;
  }

  .category-icon-wrapper {
    margin-bottom: 0.75rem;
  }

  .category-icon {
    font-size: 2.25rem;
  }

  .category-image {
    width: 60px;
    height: 60px;
    object-fit: contain;
  }

  .category-card h2 {
    color: #ffa500;
    margin-bottom: 1rem;
    font-size: 1rem;
    text-align: center;
  }

  .category-stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    width: 100%;
    justify-content: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-value {
    color: #ffa500;
    font-size: 1rem;
    font-weight: 700;
  }

  .stat-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.75rem;
  }

  .available {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(39, 174, 96, 0.2);
    color: #52be80;
    border: 1px solid rgba(39, 174, 96, 0.3);
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .coming-soon {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(128, 128, 128, 0.2);
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(128, 128, 128, 0.3);
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  [data-pct], [data-tree-pct] {
    color: rgba(255, 165, 0, 0.75);
  }

  .max-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: rgba(255, 165, 0, 0.15);
    color: rgba(255, 165, 0, 0.9);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.85rem;
    border-radius: 0 12px 0 10px;
    line-height: 1;
  }

  .max-badge.is-max {
    background: rgba(39, 174, 96, 0.2);
    color: #52be80;
  }
</style>

<script is:inline>
(function () {
  function init() {
    document.querySelectorAll('[data-category-id]').forEach(function (card) {
      var id = card.getAttribute('data-category-id');
      var totalBadges = parseInt(card.getAttribute('data-total-badges') || '0', 10);
      var totalLevels = parseInt(card.getAttribute('data-total-levels') || '0', 10);
      var badgeMap = {};
      try { badgeMap = JSON.parse(card.getAttribute('data-badge-map') || '{}'); } catch (e) { return; }

      var usedBadges = 0;
      var usedLevels = 0;
      try {
        var raw = localStorage.getItem('wh-calc-research-' + id);
        if (raw) {
          var parsed = JSON.parse(raw);
          var state = (parsed && parsed.state) ? parsed.state : parsed;
          var selected = (state && state.selectedTechnologies) ? state.selectedTechnologies : {};
          Object.keys(selected).forEach(function (techId) {
            var level = selected[techId];
            if (level > 0) {
              usedLevels += level;
              if (badgeMap[techId]) {
                var costs = badgeMap[techId];
                for (var i = 0; i < level && i < costs.length; i++) { usedBadges += costs[i]; }
              }
            }
          });
        }
      } catch (e) { /* ignore */ }

      var badgePct = totalBadges > 0 ? Math.round((usedBadges / totalBadges) * 100) : 0;
      var treePct = totalLevels > 0 ? Math.round((usedLevels / totalLevels) * 100) : 0;
      var usedEl = card.querySelector('[data-used]');
      var pctEl = card.querySelector('[data-pct]');
      var levelsUsedEl = card.querySelector('[data-levels-used]');
      var treePctEl = card.querySelector('[data-tree-pct]');
      var maxBadgeEl = card.querySelector('[data-max-badge]');
      if (usedEl) usedEl.textContent = usedBadges.toLocaleString();
      if (pctEl) pctEl.textContent = badgePct + '%';
      if (maxBadgeEl) {
        maxBadgeEl.textContent = treePct >= 100 ? 'MAX' : treePct + '%';
        maxBadgeEl.classList.toggle('is-max', treePct >= 100);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
})();
</script>
