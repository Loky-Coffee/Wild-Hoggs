---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getCurrentYear } from '../../../i18n/utils';
import { getLanguagePaths } from '../../../i18n/static-paths';
import { loadTranslations } from '../../../i18n/index';
import { Image } from 'astro:assets';
import LabSpeedButton from '../../../components/calculators/LabSpeedButton';

// Import all research category data
import allianceRecognition from '../../../data/research/alliance-recognition.json';
import unitSpecialTraining from '../../../data/research/unit-special-training.json';
import fullyArmedAlliance from '../../../data/research/fully-armed-alliance.json';
import field from '../../../data/research/field.json';
import heroTraining from '../../../data/research/hero-training.json';
import militaryStrategies from '../../../data/research/military-strategies.json';
import peaceShield from '../../../data/research/peace-shield.json';
import siegeToSeize from '../../../data/research/siege-to-seize.json';
import armyBuilding from '../../../data/research/army-building.json';
import tacticalMaster from '../../../data/research/tactical-master.json';
import riderTraining from '../../../data/research/rider-training.json';
import assaulterTraining from '../../../data/research/assaulter-training.json';
import shooterTraining from '../../../data/research/shooter-training.json';
import ageOfSteel from '../../../data/research/age-of-steel.json';
import newHome from '../../../data/research/new-home.json';
import rapidGrowth from '../../../data/research/rapid-growth.json';
import shelterBuilding from '../../../data/research/shelter-building.json';
import eliteTroops from '../../../data/research/elite-troops.json';
import hqManagement from '../../../data/research/hq-management.json';
import '../../../styles/shared-layouts.css';

// Import optimized images
import type { ImageMetadata } from 'astro';
import allianceRecognitionImg from '../../../assets/images/research/alliance-recognition.webp';
import unitSpecialTrainingImg from '../../../assets/images/research/unit-special-training.webp';
import fullyArmedAllianceImg from '../../../assets/images/research/fully-armed-alliance.webp';
import fieldImg from '../../../assets/images/research/field.webp';
import heroTrainingImg from '../../../assets/images/research/hero-training.webp';
import militaryStrategiesImg from '../../../assets/images/research/military-strategies.webp';
import peaceShieldImg from '../../../assets/images/research/peace-shield.webp';
import siegeToSeizeImg from '../../../assets/images/research/siege-to-seize.webp';
import armyBuildingImg from '../../../assets/images/research/army-building.webp';
import tacticalMasterImg from '../../../assets/images/research/tactical-master.webp';
import riderTrainingImg from '../../../assets/images/research/rider-training.webp';
import assaulterTrainingImg from '../../../assets/images/research/assaulter-training.webp';
import shooterTrainingImg from '../../../assets/images/research/shooter-training.webp';
import ageOfSteelImg from '../../../assets/images/research/age-of-steel.webp';
import newHomeImg from '../../../assets/images/research/new-home.webp';
import rapidGrowthImg from '../../../assets/images/research/rapid-growth.webp';
import shelterBuildingImg from '../../../assets/images/research/shelter-building.webp';
import eliteTroopsImg from '../../../assets/images/research/elite-troops.webp';
import hqManagementImg from '../../../assets/images/research/hq-management.webp';
import badgeIcon from '../../../assets/images/research-icons/badge.webp';
import stromIcon from '../../../assets/images/research-icons/strom.webp';
import zentIcon from '../../../assets/images/research-icons/zent.webp';

export function getStaticPaths() {
  return getLanguagePaths();
}

const lang = getLangFromUrl(Astro.url);
const translationData = await loadTranslations(lang);
const t = useTranslations(translationData);
const currentYear = getCurrentYear();
const nf = lang === 'de' ? 'de-DE' : 'en-US';
const fmtCompact = (n: number) => new Intl.NumberFormat(nf, { notation: 'compact', maximumFractionDigits: 1 }).format(n);

// Map category data by ID
const researchDataMap: Record<string, any> = {
  alliance_recognition: allianceRecognition,
  unit_special_training: unitSpecialTraining,
  fully_armed_alliance: fullyArmedAlliance,
  field: field,
  hero_training: heroTraining,
  military_strategies: militaryStrategies,
  peace_shield: peaceShield,
  siege_to_seize: siegeToSeize,
  army_building: armyBuilding,
  tactical_master: tacticalMaster,
  rider_training: riderTraining,
  assaulter_training: assaulterTraining,
  shooter_training: shooterTraining,
  age_of_steel: ageOfSteel,
  new_home: newHome,
  rapid_growth: rapidGrowth,
  shelter_building: shelterBuilding,
  elite_troops: eliteTroops,
  hq_management: hqManagement,
};

// Map optimized images by ID
const imageMap: Record<string, ImageMetadata> = {
  alliance_recognition: allianceRecognitionImg,
  unit_special_training: unitSpecialTrainingImg,
  fully_armed_alliance: fullyArmedAllianceImg,
  field: fieldImg,
  hero_training: heroTrainingImg,
  military_strategies: militaryStrategiesImg,
  peace_shield: peaceShieldImg,
  siege_to_seize: siegeToSeizeImg,
  army_building: armyBuildingImg,
  tactical_master: tacticalMasterImg,
  rider_training: riderTrainingImg,
  assaulter_training: assaulterTrainingImg,
  shooter_training: shooterTrainingImg,
  age_of_steel: ageOfSteelImg,
  new_home: newHomeImg,
  rapid_growth: rapidGrowthImg,
  shelter_building: shelterBuildingImg,
  elite_troops: eliteTroopsImg,
  hq_management: hqManagementImg,
};

const categories = [
  { id: 'unit_special_training', icon: '🎖️' },
  { id: 'fully_armed_alliance', icon: '⚔️' },
  { id: 'field', icon: '🏕️' },
  { id: 'alliance_recognition', icon: '🏆' },
  { id: 'military_strategies', icon: '📋' },
  { id: 'peace_shield', icon: '🛡️' },
  { id: 'siege_to_seize', icon: '🏰' },
  { id: 'hero_training', icon: '💪' },
  { id: 'army_building', icon: '🪖' },
  { id: 'tactical_master', icon: '🎯' },
  { id: 'rider_training', icon: '🏍️' },
  { id: 'assaulter_training', icon: '💥' },
  { id: 'shooter_training', icon: '🔫' },
  { id: 'age_of_steel', icon: '⚙️' },
  { id: 'new_home', icon: '🏠' },
  { id: 'rapid_growth', icon: '📈' },
  { id: 'shelter_building', icon: '🏗️' },
  { id: 'elite_troops', icon: '🎖️' },
  { id: 'hq_management', icon: '🏢' },
];

// Gesamtsummen über ALLE Bäume (für die Übersichts-Leiste oben)
const grandTotals = categories.reduce((acc, { id }) => {
  const c = researchDataMap[id];
  if (c) {
    acc.strom  += c.totalStrom  || 0;
    acc.zent   += c.totalZent   || 0;
    acc.badges += c.totalBadges || 0;
  }
  return acc;
}, { strom: 0, zent: 0, badges: 0 });

const breadcrumbItems = [
  { label: t('nav.home'), href: getLocalizedPath('', lang) },
  { label: t('nav.tools'), href: getLocalizedPath('tools', lang) },
  { label: t('tools.research.title') }
];
---

<PageLayout
  title={t('seo.research.title', { year: currentYear })}
  description={t('seo.research.description')}
  breadcrumbs={breadcrumbItems}
  image="/og-lab.webp"
  imageAlt={t('seo.research.title', { year: currentYear })}
>
  <div class="page-header">
    <h1>{t('seo.research.h1', { year: currentYear })}</h1>
    <p class="subtitle">{t('research.subtitle')}</p>
    <a class="compare-link" href={getLocalizedPath('tools/research/compare', lang)}>
      ⚖️ {lang === 'de' ? 'Bäume vergleichen' : 'Compare Trees'}
    </a>
    <LabSpeedButton lang={lang} client:load />

    <div class="research-totals" title={lang === 'de' ? 'Verbleibend über alle Bäume (Zeit mit deinem Lab-Speed)' : 'Remaining across all trees (time with your Lab-Speed)'}>
      <span class="rt-label">{lang === 'de' ? 'Verbleibend:' : 'Remaining:'}</span>
      <span class="rt-item">
        <img src={stromIcon.src} class="res-ico" width="18" height="18" alt="Strom" />
        <b data-total-rem-strom>–</b>
      </span>
      <span class="rt-item">
        <img src={zentIcon.src} class="res-ico" width="18" height="18" alt="Zent" />
        <b data-total-rem-zent>–</b>
      </span>
      <span class="rt-item">
        <img src={badgeIcon.src} class="res-ico" width="18" height="18" alt="Badges" />
        <b data-total-rem-badges>–</b>
      </span>
      <span class="rt-item">
        ⏱ <b data-total-rem-time>–</b>
      </span>
    </div>
  </div>

  <div class="categories-grid">
    {categories.map(({ id, icon }) => {
      const category = researchDataMap[id];
      if (!category) return null;

      const isEnabled = true; // alle Bäume aktiviert (anklickbar)
      const CardTag = isEnabled ? 'a' : 'div';

      return (
        <CardTag
          href={isEnabled ? getLocalizedPath(`tools/research/${id}`, lang) : undefined}
          class={`category-card ${!isEnabled ? 'disabled' : ''}`}
          data-category-id={id}
          data-total-badges={String(category.totalBadges)}
          data-total-levels={String(category.totalLevels)}
          data-badge-map={JSON.stringify(Object.fromEntries((category.technologies as {id:string;badgeCosts:number[]}[]).map(t => [t.id, t.badgeCosts])))}
          data-total-strom={String(category.totalStrom || 0)}
          data-total-zent={String(category.totalZent || 0)}
          data-strom-map={JSON.stringify(Object.fromEntries((category.technologies as {id:string;stromCosts?:number[]}[]).map(t => [t.id, t.stromCosts || []])))}
          data-zent-map={JSON.stringify(Object.fromEntries((category.technologies as {id:string;zentCosts?:number[]}[]).map(t => [t.id, t.zentCosts || []])))}
          data-total-time={String((category.technologies as {times?:number[]}[]).reduce((s, t) => s + (t.times?.reduce((a, b) => a + b, 0) ?? 0), 0))}
          data-time-map={JSON.stringify(Object.fromEntries((category.technologies as {id:string;times?:number[]}[]).map(t => [t.id, t.times || []])))}>

          <div class="category-icon-wrapper">
            {imageMap[id] ? (
              <Image
                src={imageMap[id]}
                alt={t(category.nameKey)}
                class="category-image"
                width={230}
                height={295}
                loading="lazy"
              />
            ) : (
              <div class="category-icon">{icon}</div>
            )}
            <div class="card-overlay">
              <h2>{t(category.nameKey)}</h2>
              <span class="max-badge" data-max-badge>0%</span>
            </div>
          </div>
          <div class="category-stats">
            {category.totalStrom ? (
              <div class="stat-line"><img src={stromIcon.src} alt="Strom" class="res-ico" width="20" height="20" /><b><span data-used-strom>0</span> / {fmtCompact(category.totalStrom)}</b> <span class="stat-pct" data-pct-strom>0%</span></div>
            ) : null}
            {category.totalZent ? (
              <div class="stat-line"><img src={zentIcon.src} alt="Zent" class="res-ico" width="20" height="20" /><b><span data-used-zent>0</span> / {fmtCompact(category.totalZent)}</b> <span class="stat-pct" data-pct-zent>0%</span></div>
            ) : null}
            {category.onlyResourcesNoBadges ? null : (
              <div class="stat-line"><img src={badgeIcon.src} alt="Badges" class="res-ico" width="20" height="20" /><b><span data-used>0</span> / {fmtCompact(category.totalBadges)}</b> <span class="stat-pct" data-pct>0%</span></div>
            )}
          </div>
        </CardTag>
      );
    })}
  </div>
</PageLayout>

<style>
  .compare-link {
    display: inline-block;
    margin-top: 0.6rem;
    padding: 0.5rem 1.1rem;
    background: rgba(255, 165, 0, 0.12);
    border: 1px solid rgba(255, 165, 0, 0.5);
    border-radius: 999px;
    color: #ffa500;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .compare-link:hover {
    background: rgba(255, 165, 0, 0.22);
  }

  .research-totals {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    gap: 0.4rem 1.1rem;
    margin: 0.8rem auto 0;
    width: fit-content;
    max-width: 100%;
    padding: 0.6rem 0.9rem;
    background: rgba(255, 165, 0, 0.06);
    border: 1px solid rgba(255, 165, 0, 0.25);
    border-radius: 10px;
    font-variant-numeric: tabular-nums;
    overflow-x: auto;
  }
  .rt-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rt-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
    color: #fff;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rt-item b { color: #ffa500; font-weight: 700; }
  .rt-item .stat-pct { color: rgba(255, 255, 255, 0.5); font-size: 0.82rem; }
  .research-totals .res-ico { flex-shrink: 0; }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
      gap: 1.25rem;
    }

    .category-card {
      padding: 1.75rem;
    }

    .category-icon-wrapper {
      max-width: 240px;
    }

    .category-icon {
      font-size: 3rem;
    }

    .category-card h2 {
      font-size: 1.2rem;
      margin-bottom: 1.25rem;
    }

    .stat-value {
      font-size: 1.1rem;
    }
  }

  .category-card {
    position: relative;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .category-card:hover {
    border-color: rgba(255, 165, 0, 0.5);
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(255, 165, 0, 0.2);
  }

  .category-card.disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .category-card.disabled:hover {
    border-color: rgba(255, 165, 0, 0.2);
    transform: none;
    box-shadow: none;
  }

  .category-icon-wrapper {
    position: relative;
    display: block;
    width: 100%;
    max-width: 210px;
    margin: 0 auto 0.5rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.6rem 0.4rem 1rem;
    text-align: center;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.82));
  }

  .card-overlay h2 {
    margin: 0;
    color: #fff;
    font-size: 1.15rem;
    line-height: 1.15;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.95);
  }

  .category-icon {
    font-size: 2.25rem;
  }

  .category-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .no-badges {
    color: #52be80;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .category-card h2 {
    color: #ffa500;
    margin-bottom: 1rem;
    font-size: 1rem;
    text-align: center;
  }

  .category-stats {
    display: grid;
    grid-template-columns: auto auto auto;
    align-items: center;
    justify-content: center;
    column-gap: 0.5rem;
    row-gap: 0.35rem;
    margin: 0 auto 1rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    font-variant-numeric: tabular-nums;
  }

  .stat-line {
    display: contents;
  }

  .stat-line b {
    justify-self: start;
  }

  .res-ico {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .stat-pct {
    color: rgba(255, 165, 0, 0.8);
    font-size: 0.82rem;
    margin-left: 0.15rem;
  }

  .stat-line b {
    color: #ffa500;
    font-weight: 700;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-value {
    color: #ffa500;
    font-size: 1rem;
    font-weight: 700;
  }

  .stat-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.75rem;
  }

  .available {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(39, 174, 96, 0.2);
    color: #52be80;
    border: 1px solid rgba(39, 174, 96, 0.3);
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .coming-soon {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(128, 128, 128, 0.2);
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(128, 128, 128, 0.3);
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  [data-pct], [data-tree-pct] {
    color: rgba(255, 165, 0, 0.75);
  }

  .max-badge {
    display: block;
    margin-top: 0.3rem;
    color: #ffd54a;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 1;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.95);
  }

  .max-badge.is-max {
    color: #6ee7a0;
  }
</style>

<script is:inline>
(function () {
  function init() {
    var profileId = localStorage.getItem('wh-active-profile') || 'local';

    // Gesamtsummen über ALLE Bäume (für die Übersichts-Leiste oben)
    var gUsedStrom = 0, gUsedZent = 0, gUsedBadges = 0;
    var gTotStrom = 0, gTotZent = 0, gTotBadges = 0;
    var gTotTimeSec = 0, gUsedTimeSec = 0;

    document.querySelectorAll('[data-category-id]').forEach(function (card) {
      var id = card.getAttribute('data-category-id');
      var totalBadges = parseInt(card.getAttribute('data-total-badges') || '0', 10);
      var totalLevels = parseInt(card.getAttribute('data-total-levels') || '0', 10);
      var badgeMap = {};
      var stromMap = {};
      var zentMap = {};
      var timeMap = {};
      try {
        badgeMap = JSON.parse(card.getAttribute('data-badge-map') || '{}');
        stromMap = JSON.parse(card.getAttribute('data-strom-map') || '{}');
        zentMap = JSON.parse(card.getAttribute('data-zent-map') || '{}');
        timeMap = JSON.parse(card.getAttribute('data-time-map') || '{}');
      } catch (e) { return; }
      var totalStrom = parseInt(card.getAttribute('data-total-strom') || '0', 10);
      var totalZent = parseInt(card.getAttribute('data-total-zent') || '0', 10);
      var totalTime = parseInt(card.getAttribute('data-total-time') || '0', 10);

      var usedBadges = 0;
      var usedStrom = 0;
      var usedZent = 0;
      var usedTimeSec = 0;
      var usedLevels = 0;
      try {
        var raw = localStorage.getItem('wh-calc-' + profileId + '-research-' + id);
        if (raw) {
          var parsed = JSON.parse(raw);
          var state = (parsed && parsed.state) ? parsed.state : parsed;
          var selected = (state && state.selectedTechnologies) ? state.selectedTechnologies : {};
          Object.keys(selected).forEach(function (techId) {
            var level = selected[techId];
            if (level > 0) {
              usedLevels += level;
              if (badgeMap[techId]) {
                var costs = badgeMap[techId];
                for (var i = 0; i < level && i < costs.length; i++) { usedBadges += costs[i]; }
              }
              if (stromMap[techId]) {
                var sc = stromMap[techId];
                for (var j = 0; j < level && j < sc.length; j++) { usedStrom += sc[j]; }
              }
              if (zentMap[techId]) {
                var zc = zentMap[techId];
                for (var k = 0; k < level && k < zc.length; k++) { usedZent += zc[k]; }
              }
              if (timeMap[techId]) {
                var tc = timeMap[techId];
                for (var m = 0; m < level && m < tc.length; m++) { usedTimeSec += tc[m]; }
              }
            }
          });
        }
      } catch (e) { /* ignore */ }

      var badgePct = totalBadges > 0 ? Math.round((usedBadges / totalBadges) * 100) : 0;
      var stromPct = totalStrom > 0 ? Math.round((usedStrom / totalStrom) * 100) : 0;
      var zentPct = totalZent > 0 ? Math.round((usedZent / totalZent) * 100) : 0;
      var treePct = totalLevels > 0 ? Math.round((usedLevels / totalLevels) * 100) : 0;
      card.__treePct = treePct;
      gUsedStrom += usedStrom; gUsedZent += usedZent; gUsedBadges += usedBadges;
      gTotStrom += totalStrom; gTotZent += totalZent; gTotBadges += totalBadges;
      gTotTimeSec += totalTime; gUsedTimeSec += usedTimeSec;
      var fc = function (n) {
        try { return new Intl.NumberFormat(undefined, { notation: 'compact', maximumFractionDigits: 1 }).format(n); }
        catch (e) { return String(n); }
      };
      var usedEl = card.querySelector('[data-used]');
      var pctEl = card.querySelector('[data-pct]');
      var usedStromEl = card.querySelector('[data-used-strom]');
      var usedZentEl = card.querySelector('[data-used-zent]');
      var pctStromEl = card.querySelector('[data-pct-strom]');
      var pctZentEl = card.querySelector('[data-pct-zent]');
      var maxBadgeEl = card.querySelector('[data-max-badge]');
      if (usedEl) usedEl.textContent = fc(usedBadges);
      if (pctEl) pctEl.textContent = badgePct + '%';
      if (usedStromEl) usedStromEl.textContent = fc(usedStrom);
      if (usedZentEl) usedZentEl.textContent = fc(usedZent);
      if (pctStromEl) pctStromEl.textContent = stromPct + '%';
      if (pctZentEl) pctZentEl.textContent = zentPct + '%';
      if (maxBadgeEl) {
        maxBadgeEl.textContent = treePct >= 100 ? 'MAX' : treePct + '%';
        maxBadgeEl.classList.toggle('is-max', treePct >= 100);
      }
    });

    // Karten nach Fortschritt sortieren:
    // angefangen (0<%<100) ganz oben -> nicht angefangen (0%) Mitte -> fertig (MAX) unten
    var grid = document.querySelector('.categories-grid');
    if (grid) {
      var rank = function (p) { return p >= 100 ? 2 : (p > 0 ? 0 : 1); };
      var cards = Array.prototype.slice.call(grid.querySelectorAll('[data-category-id]'));
      cards.sort(function (a, b) { return rank(a.__treePct || 0) - rank(b.__treePct || 0); });
      cards.forEach(function (c) { grid.appendChild(c); });
    }

    // Gesamt-Leiste oben aktualisieren (Summe aller Bäume)
    var fmtG = function (n) {
      try { return new Intl.NumberFormat(undefined, { notation: 'compact', maximumFractionDigits: 1 }).format(n); }
      catch (e) { return String(n); }
    };
    // Nur die VERBLEIBENDEN Werte (was man noch braucht) — kein "benutzt / gesamt".
    var setRem = function (sel, val) { var e = document.querySelector(sel); if (e) e.textContent = fmtG(Math.max(0, val)); };
    setRem('[data-total-rem-strom]', gTotStrom - gUsedStrom);
    setRem('[data-total-rem-zent]', gTotZent - gUsedZent);
    setRem('[data-total-rem-badges]', gTotBadges - gUsedBadges);

    // Verbleibende Zeit über ALLE Bäume, mit dem aktuellen Lab-Speed-Rabatt.
    // Die bereits gemachte Zeit zeigen wir nicht — der damalige Rabatt ist unbekannt.
    var eff = 0;
    try {
      var lsRaw = localStorage.getItem('wh-calc-' + profileId + '-labspeed-main');
      if (lsRaw) {
        var lsParsed = JSON.parse(lsRaw);
        var ls = (lsParsed && lsParsed.state) ? lsParsed.state : lsParsed;
        if (ls) eff = (ls.base || 0) + (ls.generalG ? 20 : 0) + (ls.minister ? 15 : 0) + (ls.rose ? 20 : 0);
      }
    } catch (e) { /* ignore */ }
    var remSec = Math.max(0, gTotTimeSec - gUsedTimeSec) / (1 + eff / 100);
    var fmtDur = function (s) {
      s = Math.max(0, Math.round(s));
      var d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), mm = Math.floor((s % 3600) / 60);
      var p = function (n) { return n < 10 ? '0' + n : '' + n; };
      return (d > 0 ? d + 'd ' : '') + p(h) + ':' + p(mm);
    };
    var remTimeEl = document.querySelector('[data-total-rem-time]');
    if (remTimeEl) remTimeEl.textContent = fmtDur(remSec);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
  window.addEventListener('wh-profile-change', init);
})();
</script>
