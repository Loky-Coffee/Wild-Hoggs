---
import PageLayout from '../../layouts/PageLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { getLanguagePaths } from '../../i18n/static-paths';
import { loadTranslations } from '../../i18n/index';
import '../../styles/shared-layouts.css';

export function getStaticPaths() {
  return getLanguagePaths();
}

const lang = getLangFromUrl(Astro.url);
const translationData = await loadTranslations(lang);
const t = useTranslations(translationData);

const breadcrumbItems = [
  { label: t('nav.home'), href: getLocalizedPath('', lang) },
  { label: t('about.title') }
];

const siteUrl = Astro.site || new URL('https://wild-hoggs.com/');
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ediva',
  description: t('seo.about.description'),
  url: siteUrl.toString(),
};
---

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<PageLayout
  title={t('seo.about.title')}
  description={t('seo.about.description')}
  breadcrumbs={breadcrumbItems}
>
  <div class="page-header">
    <h1>{t('seo.about.h1')}</h1>
  </div>

  <div class="content-container">

    <!-- Profile Card -->
    <section class="profile-card">
      <div class="profile-avatar">E</div>
      <div class="profile-info">
        <h2 class="profile-name">Ediva</h2>
        <p class="profile-tagline">{t('about.hero.tagline')}</p>
      </div>
    </section>

    <!-- Personal Intro -->
    <section class="about-section">
      <h2>{t('about.intro.title')}</h2>
      <p>{t('about.intro.text')}</p>
    </section>

    <!-- About This Site -->
    <section class="about-section">
      <h2>{t('about.site.title')}</h2>
      <p>{t('about.site.text')}</p>
    </section>

    <!-- What You'll Find -->
    <section class="features-section">
      <h2>{t('about.what.title')}</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🧮</div>
          <h3>{t('about.what.tools')}</h3>
          <p>{t('about.what.tools.text')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📅</div>
          <h3>{t('about.what.guides')}</h3>
          <p>{t('about.what.guides.text')}</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎁</div>
          <h3>{t('about.what.codes')}</h3>
          <p>{t('about.what.codes.text')}</p>
        </div>
      </div>
    </section>

    <!-- Info Strip -->
    <section class="info-section">
      <div class="info-grid">
        <div class="info-card">
          <span class="info-label">{t('info.game')}</span>
          <span class="info-value">Last-Z</span>
        </div>
        <div class="info-card">
          <span class="info-label">{t('info.server')}</span>
          <span class="info-value">395</span>
        </div>
        <div class="info-card">
          <span class="info-label">{t('info.status')}</span>
          <span class="info-value">{t('info.status.active')}</span>
        </div>
      </div>
    </section>

    <!-- Support (Buy me a coffee placeholder) -->
    <section class="support-section">
      <h2>{t('about.support.title')}</h2>
      <p>{t('about.support.text')}</p>
      <a
        href="https://www.buymeacoffee.com/ediva"
        target="_blank"
        rel="noopener noreferrer"
        class="bmc-button"
      >
        ☕ Buy me a coffee
      </a>
    </section>

  </div>
</PageLayout>

<style>
  .content-container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Profile Card */
  .profile-card {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.3);
    border-radius: 16px;
    padding: 2rem 2.5rem;
  }

  .profile-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ffa500, #ff6a00);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    font-weight: 700;
    color: #1a1a1a;
    flex-shrink: 0;
    box-shadow: 0 0 24px rgba(255, 165, 0, 0.35);
  }

  .profile-name {
    color: #ffa500;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .profile-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1rem;
    margin: 0;
  }

  /* Text Sections */
  .about-section {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 165, 0, 0.15);
    border-radius: 12px;
    padding: 2rem;
  }

  .about-section h2 {
    color: #ffa500;
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }

  .about-section p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
  }

  /* Features Grid */
  .features-section {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 165, 0, 0.15);
    border-radius: 12px;
    padding: 2rem;
  }

  .features-section h2 {
    color: #ffa500;
    font-size: 1.5rem;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    background: rgba(255, 165, 0, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }

  .feature-card:hover {
    border-color: rgba(255, 165, 0, 0.5);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(255, 165, 0, 0.15);
  }

  .feature-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    color: #ffa500;
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
  }

  .feature-card p {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  /* Info Strip */
  .info-section {
    margin: 0;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .info-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 165, 0, 0.2);
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
  }

  .info-label {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-value {
    color: #ffa500;
    font-size: 1.3rem;
    font-weight: 700;
  }

  /* Support Section */
  .support-section {
    background: rgba(255, 165, 0, 0.06);
    border: 1px solid rgba(255, 165, 0, 0.25);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .support-section h2 {
    color: #ffa500;
    font-size: 1.5rem;
    margin: 0 0 0.75rem;
  }

  .support-section p {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .bmc-button {
    display: inline-block;
    margin-top: 1.25rem;
    padding: 0.65rem 1.6rem;
    background: #ffa500;
    color: #1a1a1a;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .bmc-button:hover {
    background: #ff8c00;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .profile-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
      gap: 1rem;
    }

    .features-grid,
    .info-grid {
      grid-template-columns: 1fr;
    }

    .profile-name {
      font-size: 1.6rem;
    }
  }
</style>
